# ============================================================================
# THIS FILE IS OPTIONAL FOR LOCAL DEVELOPMENT.
#
# With no .env file at all, this app runs in LOCAL MODE: a zero-config
# SQLite database at ./local.db. Just run:
#   npm install
#   npm run db:init
#   npm run db:seed
#   npm run dev
# No account, no credentials, nothing below is required.
#
# To deploy against a real Supabase/Postgres project instead, copy this file
# to .env and fill in the Supabase values below — the app automatically
# switches to SUPABASE MODE the moment NEXT_PUBLIC_SUPABASE_URL and
# SUPABASE_SERVICE_ROLE_KEY are both set. No code changes needed either way.
# ============================================================================

# Public Supabase project URL and anon key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service-role key — SERVER-ONLY. Never import this into a Client Component
# or any file under app/**/page.tsx. Used only in Route Handlers (app/api/**)
# and standalone scripts in scripts/.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-for-testing-and-scripts

# Direct Postgres connection string — required for scripts/db-init.js in
# Supabase mode, which runs raw DDL (CREATE TABLE) that the Supabase JS
# client cannot execute. Find this in the Supabase dashboard under Project
# Settings -> Database -> Connection string (use the "URI" / non-pooling
# connection string). Not used at all in local SQLite mode.
SUPABASE_DB_URL=postgres://postgres:your-db-password@db.your-supabase-project.supabase.co:5432/postgres

# Comma-separated list of origins allowed to call this API via CORS, e.g.
# the plain-logger-frontend app's local dev URL and its deployed URL.
# No default — CORS is closed until you set this. Applies in both modes.
CORS_ALLOWED_ORIGINS=http://localhost:3001,https://plain-logger-frontend.example.com
